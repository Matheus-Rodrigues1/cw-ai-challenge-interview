# =============================================================================
# Database — local Docker Compose
# Change these if you want a different user/password for the local stack.
# =============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_local_password
POSTGRES_DB=cloudwalk_transactions

# pgAdmin web UI (http://localhost:8080)
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password

# =============================================================================
# Alert email — use a hosted provider (you do NOT run an SMTP server yourself).
# The app only needs SMTP credentials from one of these free/free-tier services.
# =============================================================================

ALERT_EMAIL_TO=your-inbox@gmail.com
# "From" must be allowed by the provider (verified domain or single sender).
ALERT_EMAIL_FROM=your-inbox@gmail.com

# -----------------------------------------------------------------------------
# Option A — SendGrid (free tier ~100 emails/day): https://sendgrid.com
# Create API key; verify a single sender or domain in the dashboard.
# SMTP_USER must be the literal word: apikey
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SSL=
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Option B — Brevo (free ~300 emails/day): https://www.brevo.com
# SMTP & API → generate SMTP key; use the login + key shown there.
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SSL=
# SMTP_USER=your-smtp-login@example.com
# SMTP_PASS=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Option C — Resend (free tier): https://resend.com
# Domains → verify domain or use onboarding@resend.dev for tests.
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SSL=
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Option D — Gmail (Google's hosted SMTP; not your own server)
# Requires 2FA + App Password: https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SSL=
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx

# -----------------------------------------------------------------------------
# Optional: implicit SSL (e.g. port 465) — set SMTP_SSL=true
# -----------------------------------------------------------------------------
# SMTP_SSL=true

# Optional
# SLACK_WEBHOOK_URL=
# ALERT_ON_EVALUATE=false
